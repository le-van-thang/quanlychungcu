<Window x:Class="WpfApp1.CanHoDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thông tin căn hộ" Height="400" Width="720"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White">

    <Border CornerRadius="8" BorderBrush="#D5DBDB" BorderThickness="1" Padding="20" Background="White">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock x:Name="lblHeader" Text="Thông tin căn hộ"
                       FontSize="20" FontWeight="Bold" Foreground="#2C3E50" />

            <!-- Form -->
            <Grid Grid.Row="1" Margin="0,15,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Số căn hộ (bắt buộc) -->
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="5">
                    <TextBlock Text="Số căn hộ (bắt buộc)" FontWeight="Bold"/>
                    <TextBox x:Name="txtSoCanHo" Margin="0,5,0,0" />
                </StackPanel>

                <!-- Số tầng (bắt buộc) -->
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="5">
                    <TextBlock Text="Số tầng (bắt buộc)" FontWeight="Bold"/>
                    <ComboBox x:Name="cbTang" Margin="0,5,0,0"
                              DisplayMemberPath="TenTang"
                              SelectedValuePath="TangID"/>
                </StackPanel>

                <!-- Diện tích -->
                <StackPanel Grid.Row="1" Grid.Column="0" Margin="5">
                    <TextBlock Text="Diện tích (m²)" FontWeight="Bold"/>
                    <TextBox x:Name="txtDienTich" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Giá trị -->
                <StackPanel Grid.Row="1" Grid.Column="1" Margin="5">
                    <TextBlock Text="Giá trị" FontWeight="Bold"/>
                    <TextBox x:Name="txtGiaTri" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Số cư dân (readonly) -->
                <StackPanel Grid.Row="2" Grid.Column="0" Margin="5">
                    <TextBlock Text="Số cư dân" FontWeight="Bold"/>
                    <TextBox x:Name="txtSoCuDan" Margin="0,5,0,0" IsReadOnly="True"/>
                </StackPanel>
            </Grid>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnSave" Content="Lưu" Width="110" Height="35"
                        Background="#58D68D" Foreground="White" Margin="5"
                        Click="BtnSave_Click"/>
                <Button Content="Hủy" Width="110" Height="35"
                        Background="#7D3C98" Foreground="White" Margin="5"
                        Click="BtnClose_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
