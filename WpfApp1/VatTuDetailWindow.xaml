<Window x:Class="WpfApp1.VatTuDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thông tin vật tư" Height="410" Width="720"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="White">
    <Border CornerRadius="8" BorderBrush="#D5DBDB" BorderThickness="1" Padding="20" Background="White">
        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="lblHeader" Text="Thông tin vật tư"
                 FontSize="20" FontWeight="Bold" Foreground="#2C3E50"/>

            <Grid Grid.Row="1" Margin="0,14,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ID (readonly) -->
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="5">
                    <TextBlock Text="ID (tự tăng)" FontWeight="Bold"/>
                    <TextBox x:Name="txtId" Margin="0,5,0,0" IsReadOnly="True"/>
                </StackPanel>

                <!-- Tên vật tư -->
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="5">
                    <TextBlock Text="Tên vật tư (bắt buộc)" FontWeight="Bold"/>
                    <TextBox x:Name="txtTenVatTu" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Đơn vị -->
                <StackPanel Grid.Row="1" Grid.Column="0" Margin="5">
                    <TextBlock Text="Đơn vị" FontWeight="Bold"/>
                    <TextBox x:Name="txtDonVi" Margin="0,5,0,0" />
                </StackPanel>

                <!-- Số lượng -->
                <StackPanel Grid.Row="1" Grid.Column="1" Margin="5">
                    <TextBlock Text="Số lượng" FontWeight="Bold"/>
                    <TextBox x:Name="txtSoLuong" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Giá -->
                <StackPanel Grid.Row="2" Grid.Column="0" Margin="5">
                    <TextBlock Text="Giá" FontWeight="Bold"/>
                    <TextBox x:Name="txtGia" Margin="0,5,0,0" />
                </StackPanel>

                <!-- Ghi chú -->
                <StackPanel Grid.Row="2" Grid.Column="1" Margin="5">
                    <TextBlock Text="Ghi chú" FontWeight="Bold"/>
                    <TextBox x:Name="txtGhiChu" Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnSave" Content="Lưu" Width="110" Height="36"
                Background="#58D68D" Foreground="White" Margin="5"
                Click="BtnSave_Click"/>
                <Button Content="Hủy" Width="110" Height="36"
                Background="#7D3C98" Foreground="White" Margin="5"
                Click="BtnClose_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
