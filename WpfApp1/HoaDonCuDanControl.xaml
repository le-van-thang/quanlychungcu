<UserControl x:Class="WpfApp1.HoaDonCuDanControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F6F7">
    <Border Background="White" CornerRadius="10" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0" Text="📑 Hóa đơn cư dân"
                 FontSize="20" FontWeight="Bold"
                 Foreground="#2C3E50" Margin="0,0,0,15"/>

            <!-- Search -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
                <TextBox x:Name="txtSearch" Width="320" Height="35"
                 VerticalContentAlignment="Center" FontSize="14"
                 Margin="0,0,10,0" Padding="8"
                 BorderBrush="#BDC3C7" BorderThickness="1"
                 ToolTip="Tìm theo số căn / trạng thái"/>
                <Button Content="🔍 Tìm kiếm" Width="120" Height="35"
                        Background="#7D3C98" Foreground="White"
                        FontWeight="Bold" BorderThickness="0"
                        Cursor="Hand" Click="BtnSearch_Click"/>
                <Button Content="🔄 Tải lại" Width="120" Height="35"
                        Margin="10,0,0,0"
                        Background="#2ECC71" Foreground="White"
                        FontWeight="Bold" BorderThickness="0"
                        Cursor="Hand" Click="BtnReload_Click"/>
            </StackPanel>

            <!-- Actions -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,15">
                <Button Content="👁 Xem"   Width="100" Height="35" Margin="5,0"
                Background="#5DADE2" Foreground="White" FontWeight="Bold"
                BorderThickness="0" Cursor="Hand" Click="BtnView_Click"/>
                <Button Content="➕ Thêm"  Width="100" Height="35" Margin="5,0"
                Background="#58D68D" Foreground="White" FontWeight="Bold"
                BorderThickness="0" Cursor="Hand" Click="BtnAdd_Click"/>
                <Button Content="✏ Sửa"   Width="100" Height="35" Margin="5,0"
                Background="#F5B041" Foreground="White" FontWeight="Bold"
                BorderThickness="0" Cursor="Hand" Click="BtnEdit_Click"/>
                <Button Content="🗑 Xóa"   Width="100" Height="35" Margin="5,0"
                Background="#E74C3C" Foreground="White" FontWeight="Bold"
                BorderThickness="0" Cursor="Hand" Click="BtnDelete_Click"/>
            </StackPanel>

            <!-- Grid -->
            <DataGrid x:Name="dgHoaDon" Grid.Row="3"
          AutoGenerateColumns="False" IsReadOnly="True"
          CanUserAddRows="False" HeadersVisibility="Column"
          AlternatingRowBackground="#F8F9F9"
          GridLinesVisibility="None" RowHeight="35" FontSize="14"
          BorderBrush="#D5DBDB" BorderThickness="1">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding HoaDonID}" Width="70"/>
                    <DataGridTextColumn Header="Số căn" Binding="{Binding SoCanHo}" Width="110"/>
                    <DataGridTextColumn Header="Cư dân" Binding="{Binding CuDan}" Width="150"/>
                    <DataGridTextColumn Header="Dịch vụ" Binding="{Binding LoaiDichVu}" Width="120"/>
                    <DataGridTextColumn Header="Số tiền" Binding="{Binding SoTien, StringFormat={}{0:N0}}" Width="140"/>
                    <DataGridTextColumn Header="Ngày lập" Binding="{Binding NgayLap, StringFormat={}{0:dd/MM/yyyy}}" Width="150"/>
                    <DataGridTextColumn Header="Trạng thái" Binding="{Binding TrangThai}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>

        </Grid>
    </Border>
</UserControl>
