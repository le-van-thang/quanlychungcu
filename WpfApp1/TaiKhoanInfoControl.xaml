<UserControl x:Class="WpfApp1.TaiKhoanInfoControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F6F7">
    <UserControl.Resources>
        <!-- Palette -->
        <Color x:Key="ColPrimary">#6750A4</Color>
        <Color x:Key="ColPrimaryDark">#57408F</Color>
        <Color x:Key="ColOk">#2E7D32</Color>
        <Color x:Key="ColWarn">#ED6C02</Color>
        <Color x:Key="ColDanger">#D32F2F</Color>
        <SolidColorBrush x:Key="BPrimary" Color="{StaticResource ColPrimary}"/>
        <SolidColorBrush x:Key="BPrimaryDark" Color="{StaticResource ColPrimaryDark}"/>
        <SolidColorBrush x:Key="BOk" Color="{StaticResource ColOk}"/>
        <SolidColorBrush x:Key="BWarn" Color="{StaticResource ColWarn}"/>
        <SolidColorBrush x:Key="BDanger" Color="{StaticResource ColDanger}"/>
        <SolidColorBrush x:Key="TextTitle" Color="#212121"/>
        <SolidColorBrush x:Key="TextBody" Color="#333"/>

        <!-- Card -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18" ShadowDepth="1" Opacity="0.18"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Title" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextTitle}"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- Inputs -->
        <Style x:Key="InputBase" TargetType="Control">
            <Setter Property="Height" Value="38"/>
            <Setter Property="BorderBrush" Value="#D7DBE2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Foreground" Value="{StaticResource TextBody}"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style TargetType="TextBox" BasedOn="{StaticResource InputBase}"/>
        <Style TargetType="DatePicker" BasedOn="{StaticResource InputBase}"/>
        <Style TargetType="PasswordBox" BasedOn="{StaticResource InputBase}"/>

        <!-- Button pill -->
        <Style x:Key="PillButton" TargetType="Button">
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="20">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#C8CCD4"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Thông tin tài khoản"
                   Style="{StaticResource Title}" Margin="4,2,4,16"/>

        <!-- Main layout -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="310"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT CARD -->
            <Border Grid.Column="0" Style="{StaticResource Card}">
                <StackPanel>
                    <Grid Width="180" Height="180" HorizontalAlignment="Center" Margin="0,8,0,16">
                        <Ellipse Fill="#F8F8FA" Stroke="#E6E6EE" StrokeThickness="1"/>
                        <Image x:Name="imgAvatar" Stretch="UniformToFill" ClipToBounds="True">
                            <Image.Clip>
                                <EllipseGeometry Center="90,90" RadiusX="90" RadiusY="90"/>
                            </Image.Clip>
                        </Image>
                        <TextBlock x:Name="txtInitials" Text="NA" Foreground="#8188A0"
                                   FontWeight="Bold" FontSize="48"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Visibility="Collapsed"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="btnChangeAvatar" Content="Thay đổi ảnh"
                                Background="{StaticResource BPrimary}"
                                Style="{StaticResource PillButton}"
                                Margin="0,0,10,0"
                                Click="BtnChangeAvatar_Click"/>
                        <Button x:Name="btnRemoveAvatar" Content="Xóa ảnh"
                                Background="{StaticResource BDanger}"
                                Style="{StaticResource PillButton}"
                                Click="BtnRemoveAvatar_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- RIGHT CARD -->
            <Border Grid.Column="2" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Họ tên -->
                    <TextBlock Grid.Row="0" Text="Họ và tên" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="txtHoTen" Grid.Row="1" Margin="0,0,0,14" IsReadOnly="True"/>

                    <!-- Ngày sinh -->
                    <TextBlock Grid.Row="2" Text="Ngày sinh" Style="{StaticResource FieldLabel}"/>
                    <DatePicker x:Name="dpNgaySinh" Grid.Row="3" Margin="0,0,0,14" IsEnabled="False"/>

                    <!-- Đổi mật khẩu -->
                    <CheckBox x:Name="ckChangePw" Grid.Row="4" Content="Thay đổi mật khẩu"
                              Margin="0,0,0,8" IsEnabled="False"
                              Checked="ckChangePw_Checked"
                              Unchecked="ckChangePw_Unchecked"/>

                    <StackPanel x:Name="pwPanel" Grid.Row="4" Margin="0,34,0,0" Visibility="Collapsed">
                        <TextBlock Text="Mật khẩu hiện tại" Style="{StaticResource FieldLabel}"/>
                        <PasswordBox x:Name="pbOldPw" Margin="0,0,0,10"/>
                        <TextBlock Text="Mật khẩu mới" Style="{StaticResource FieldLabel}"/>
                        <PasswordBox x:Name="pbNewPw" Margin="0,0,0,10"/>
                        <TextBlock Text="Xác nhận mật khẩu mới" Style="{StaticResource FieldLabel}"/>
                        <PasswordBox x:Name="pbConfirmPw"/>
                    </StackPanel>

                    <!-- Buttons -->
                    <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                        <Button x:Name="btnEdit" Content="Chỉnh sửa"
                                Background="{StaticResource BPrimary}" Style="{StaticResource PillButton}"
                                Click="BtnEdit_Click"/>
                        <Button x:Name="btnSave" Content="Lưu"
                                Margin="10,0,0,0" Visibility="Collapsed"
                                Background="{StaticResource BOk}" Style="{StaticResource PillButton}"
                                Click="BtnSave_Click"/>
                        <Button x:Name="btnCancel" Content="Hủy"
                                Margin="10,0,0,0" Visibility="Collapsed"
                                Background="{StaticResource BWarn}" Style="{StaticResource PillButton}"
                                Click="BtnCancel_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
