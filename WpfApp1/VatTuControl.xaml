<UserControl x:Class="WpfApp1.VatTuControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F6F7"
             SnapsToDevicePixels="True" UseLayoutRounding="True">
    <Border Background="White" CornerRadius="10" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="15"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0" Text="🛠 Quản lý vật tư"
                 FontSize="20" FontWeight="Bold"
                 Foreground="#2C3E50" Margin="0,0,0,15"/>

            <!-- Search -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
                <TextBox x:Name="txtSearch" Width="300" Height="35"
                 VerticalContentAlignment="Center" FontSize="14"
                 Margin="0,0,10,0" Padding="8"
                 BorderBrush="#BDC3C7" BorderThickness="1"
                 ToolTip="Tìm theo tên vật tư / đơn vị"/>
                <Button Content="🔍 Tìm kiếm" Width="120" Height="35"
                Background="#7D3C98" Foreground="White"
                FontWeight="Bold" BorderThickness="0"
                Cursor="Hand" Click="BtnSearch_Click"/>
                <Button Content="🔄 Tải lại" Width="120" Height="35"
                Margin="10,0,0,0" Background="#16A085" Foreground="White"
                FontWeight="Bold" BorderThickness="0"
                Cursor="Hand" Click="BtnReload_Click"/>
            </StackPanel>

            <!-- Actions -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,0">
                <Button Content="👁 Xem" Width="100" Height="35"
                Margin="5,0" Background="#5DADE2" Foreground="White"
                FontWeight="Bold" BorderThickness="0"
                Cursor="Hand" Click="BtnView_Click"/>
                <Button Content="➕ Thêm" Width="100" Height="35"
                Margin="5,0" Background="#58D68D" Foreground="White"
                FontWeight="Bold" BorderThickness="0"
                Cursor="Hand" Click="BtnAdd_Click"/>
                <Button Content="✏ Sửa" Width="100" Height="35"
                Margin="5,0" Background="#F5B041" Foreground="White"
                FontWeight="Bold" BorderThickness="0"
                Cursor="Hand" Click="BtnEdit_Click"/>
                <Button Content="🗑 Xóa" Width="100" Height="35"
                Margin="5,0" Background="#E74C3C" Foreground="White"
                FontWeight="Bold" BorderThickness="0"
                Cursor="Hand" Click="BtnDelete_Click"/>
            </StackPanel>

            <!-- DataGrid -->
            <DataGrid x:Name="dgVatTu" Grid.Row="4"
                AutoGenerateColumns="False" IsReadOnly="True"
                CanUserAddRows="False" HeadersVisibility="Column"
                AlternatingRowBackground="#F8F9F9"
                GridLinesVisibility="None" RowHeight="38" FontSize="14"
                ColumnHeaderHeight="38"
                BorderBrush="#D5DBDB" BorderThickness="1">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Padding" Value="8,0,8,0"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"        Binding="{Binding VatTuID}"  Width="70"/>
                    <DataGridTextColumn Header="Tên vật tư" Binding="{Binding TenVatTu}" Width="*"/>
                    <DataGridTextColumn Header="Đơn vị"    Binding="{Binding DonVi}"    Width="120"/>
                    <DataGridTextColumn Header="Số lượng"  Binding="{Binding SoLuong}"  Width="110"/>
                    <DataGridTextColumn Header="Giá"       Binding="{Binding Gia, StringFormat={}{0:N0}}" Width="140"/>
                    <DataGridTextColumn Header="Ghi chú"   Binding="{Binding GhiChu}"   Width="220"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</UserControl>
