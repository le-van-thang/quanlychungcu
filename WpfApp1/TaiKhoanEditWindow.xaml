<Window x:Class="WpfApp1.TaiKhoanEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tài khoản"
        Height="420" Width="720"
        WindowStartupLocation="CenterOwner"
        Background="#F4F6F7"
        ResizeMode="CanResize"
        WindowStyle="SingleBorderWindow">

    <Border Background="White" CornerRadius="10" Padding="20" Margin="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Header -->
                <RowDefinition Height="*"/>
                <!-- Form -->
                <RowDefinition Height="Auto"/>
                <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <DockPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock x:Name="lblTitle"
                           Text="Thêm tài khoản"
                           FontSize="20" FontWeight="Bold"
                           Foreground="#2C3E50"
                           DockPanel.Dock="Left"/>
                <CheckBox x:Name="chkActive"
                          Content="Hoạt động"
                          Margin="12,0,0,0"
                          VerticalAlignment="Center"
                          DockPanel.Dock="Right"/>
            </DockPanel>

            <!-- Form -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Username -->
                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,12,10"
                           VerticalAlignment="Center" Text="Username:"/>
                <TextBox x:Name="txtUsername"
                         Grid.Row="0" Grid.Column="1" Margin="0,0,0,10"
                         Height="32" VerticalContentAlignment="Center"/>

                <!-- Họ tên -->
                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,12,10"
                           VerticalAlignment="Center" Text="Họ tên:"/>
                <TextBox x:Name="txtHoTen"
                         Grid.Row="1" Grid.Column="1" Margin="0,0,0,10"
                         Height="32" VerticalContentAlignment="Center"/>

                <!-- Email -->
                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,12,10"
                           VerticalAlignment="Center" Text="Email:"/>
                <TextBox x:Name="txtEmail"
                         Grid.Row="2" Grid.Column="1" Margin="0,0,0,10"
                         Height="32" VerticalContentAlignment="Center"/>

                <!-- Vai trò -->
                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,12,10"
                           VerticalAlignment="Center" Text="Vai trò:"/>
                <ComboBox x:Name="cboVaiTro"
                          Grid.Row="3" Grid.Column="1" Margin="0,0,0,10"
                          Height="32">
                    <ComboBoxItem Content="User" IsSelected="True"/>
                    <ComboBoxItem Content="Manager"/>
                    <ComboBoxItem Content="Admin"/>
                </ComboBox>

                <!-- Mật khẩu mới -->
                <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,12,10"
                           VerticalAlignment="Center" Text="Mật khẩu mới:"/>
                <PasswordBox x:Name="pwdNew"
                             Grid.Row="4" Grid.Column="1" Margin="0,0,0,10"
                             Height="32"/>

                <!-- Nhập lại mật khẩu -->
                <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,0,12,0"
                           VerticalAlignment="Center" Text="Nhập lại:"/>
                <PasswordBox x:Name="pwdRe"
                             Grid.Row="5" Grid.Column="1"
                             Height="32"/>
            </Grid>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button x:Name="btnSave" Content="Lưu"
                        Width="110" Height="36" Margin="0,0,10,0"
                        Background="#27AE60" Foreground="White"
                        BorderThickness="0" Click="BtnSave_Click"/>
                <Button Content="Đóng" Width="110" Height="36"
                        Background="#95A5A6" Foreground="White"
                        BorderThickness="0" Click="BtnClose_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
