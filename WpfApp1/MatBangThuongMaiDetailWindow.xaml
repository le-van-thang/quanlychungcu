<Window x:Class="WpfApp1.MatBangThuongMaiDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thông tin mặt bằng thương mại" Height="300" Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White">

    <Border CornerRadius="8" BorderBrush="#D5DBDB" BorderThickness="1" Padding="20" Background="White">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock x:Name="lblHeader" Text="Thông tin mặt bằng"
                       FontSize="20" FontWeight="Bold" Foreground="#2C3E50" />

            <!-- Form -->
            <Grid Grid.Row="1" Margin="0,15,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Tên mặt bằng -->
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="5">
                    <TextBlock Text="Tên mặt bằng (bắt buộc)" FontWeight="Bold"/>
                    <TextBox x:Name="txtTenMatBang" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Diện tích -->
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="5">
                    <TextBlock Text="Diện tích (m²) (bắt buộc)" FontWeight="Bold"/>
                    <TextBox x:Name="txtDienTich" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Giá thuê -->
                <StackPanel Grid.Row="1" Grid.Column="0" Margin="5">
                    <TextBlock Text="Giá thuê (bắt buộc)" FontWeight="Bold"/>
                    <TextBox x:Name="txtGiaThue" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- ID (readonly) -->
                <StackPanel Grid.Row="1" Grid.Column="1" Margin="5">
                    <TextBlock Text="Mã MB (tự tăng)" FontWeight="Bold"/>
                    <TextBox x:Name="txtId" Margin="0,5,0,0" IsReadOnly="True"/>
                </StackPanel>
            </Grid>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnSave" Content="Lưu" Width="110" Height="35"
                        Background="#58D68D" Foreground="White" Margin="5"
                        Click="BtnSave_Click"/>
                <Button Content="Hủy" Width="110" Height="35"
                        Background="#7D3C98" Foreground="White" Margin="5"
                        Click="BtnClose_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
