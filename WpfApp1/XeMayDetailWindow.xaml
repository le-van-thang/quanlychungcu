<Window x:Class="WpfApp1.XeMayDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thông tin xe máy" Height="320" Width="620"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="White">
    <Border CornerRadius="8" BorderBrush="#D5DBDB" BorderThickness="1" Padding="20" Background="White">
        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="lblHeader" Text="Thông tin xe máy"
                 FontSize="20" FontWeight="Bold" Foreground="#2C3E50"/>

            <Grid Grid.Row="1" Margin="0,14,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="5">
                    <TextBlock Text="ID xe máy (tự tăng)" FontWeight="Bold"/>
                    <TextBox x:Name="txtId" Margin="0,5,0,0" IsReadOnly="True"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" Margin="5">
                    <TextBlock Text="Biển số (bắt buộc)" FontWeight="Bold"/>
                    <TextBox x:Name="txtBKS" Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="5">
                    <TextBlock Text="Cư dân (bắt buộc)" FontWeight="Bold"/>
                    <ComboBox x:Name="cbCuDan" Margin="0,5,0,0"
                    DisplayMemberPath="HoTen"
                    SelectedValuePath="CuDanID"/>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnSave" Content="Lưu" Width="110" Height="36"
                Background="#58D68D" Foreground="White" Margin="5"
                Click="BtnSave_Click"/>
                <Button Content="Hủy" Width="110" Height="36"
                Background="#7D3C98" Foreground="White" Margin="5"
                Click="BtnClose_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
