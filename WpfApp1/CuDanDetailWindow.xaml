<Window x:Class="WpfApp1.CuDanDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thông tin cư dân" Height="420" Width="650"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White">

    <Border CornerRadius="8" BorderBrush="#D5DBDB" BorderThickness="1" Padding="20" Background="White">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock x:Name="lblHeader" Text="Thông tin cư dân" 
                       FontSize="20" FontWeight="Bold" Foreground="#2C3E50" />

            <!-- Form -->
            <Grid Grid.Row="1" Margin="0,15,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ID -->
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="5">
                    <TextBlock Text="ID Cư dân" FontWeight="Bold"/>
                    <TextBox x:Name="txtId" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Họ tên -->
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="5">
                    <TextBlock Text="Họ tên" FontWeight="Bold"/>
                    <TextBox x:Name="txtTen" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Ngày sinh -->
                <StackPanel Grid.Row="1" Grid.Column="0" Margin="5">
                    <TextBlock Text="Ngày sinh" FontWeight="Bold"/>
                    <DatePicker x:Name="dpNgaySinh" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Điện thoại -->
                <StackPanel Grid.Row="1" Grid.Column="1" Margin="5">
                    <TextBlock Text="Điện thoại" FontWeight="Bold"/>
                    <TextBox x:Name="txtDienThoai" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Email -->
                <StackPanel Grid.Row="2" Grid.Column="0" Margin="5">
                    <TextBlock Text="Email" FontWeight="Bold"/>
                    <TextBox x:Name="txtEmail" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Số căn hộ -->
                <StackPanel Grid.Row="2" Grid.Column="1" Margin="5">
                    <TextBlock Text="Số căn hộ" FontWeight="Bold"/>
                    <ComboBox x:Name="cbCanHo" Margin="0,5,0,0"
                              DisplayMemberPath="SoCanHo"
                              SelectedValuePath="CanHoID"/>
                </StackPanel>
            </Grid>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnSave" Content="Lưu" Width="100" Height="35" 
                        Background="#58D68D" Foreground="White" Margin="5"
                        Click="BtnSave_Click"/>
                <Button Content="Hủy" Width="100" Height="35" 
                        Background="#7D3C98" Foreground="White" Margin="5"
                        Click="BtnClose_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
