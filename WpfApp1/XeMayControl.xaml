<UserControl x:Class="WpfApp1.XeMayControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F6F7"
             SnapsToDevicePixels="True" UseLayoutRounding="True">
    <Border Background="White" CornerRadius="10" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Header -->
                <RowDefinition Height="Auto"/>
                <!-- Search -->
                <RowDefinition Height="Auto"/>
                <!-- Actions -->
                <RowDefinition Height="*"/>
                <!-- DataGrid -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0" Text="🏍 Quản lý xe máy"
                       FontSize="20" FontWeight="Bold"
                       Foreground="#2C3E50" Margin="0,0,0,15"/>

            <!-- Search -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
                <TextBox x:Name="txtSearch" Width="300" Height="35"
                         VerticalContentAlignment="Center" FontSize="14"
                         Margin="0,0,10,0" Padding="8"
                         BorderBrush="#BDC3C7" BorderThickness="1"
                         ToolTip="Tìm theo biển số / tên cư dân"/>
                <Button Content="🔍 Tìm kiếm" Width="120" Height="35"
                        Background="#7D3C98" Foreground="White"
                        FontWeight="Bold" BorderThickness="0"
                        Cursor="Hand" Click="BtnSearch_Click"/>
                <Button Content="🔄 Tải lại" Width="100" Height="35" Margin="10,0,0,0"
                        Background="#2ECC71" Foreground="White"
                        FontWeight="Bold" BorderThickness="0"
                        Cursor="Hand" Click="BtnLoad_Click"/>
            </StackPanel>

            <!-- Actions -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,15">
                <Button Content="👁 Xem" Width="100" Height="35"
                        Margin="5,0" Background="#5DADE2" Foreground="White"
                        FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                        Click="BtnView_Click"/>
                <Button Content="➕ Thêm" Width="100" Height="35"
                        Margin="5,0" Background="#58D68D" Foreground="White"
                        FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                        Click="BtnAdd_Click"/>
                <Button Content="✏ Sửa" Width="100" Height="35"
                        Margin="5,0" Background="#F5B041" Foreground="White"
                        FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                        Click="BtnEdit_Click"/>
                <Button Content="🗑 Xóa" Width="100" Height="35"
                        Margin="5,0" Background="#E74C3C" Foreground="White"
                        FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                        Click="BtnDelete_Click"/>
            </StackPanel>

            <!-- Grid -->
            <DataGrid x:Name="dgXeMay" Grid.Row="3"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserAddRows="False" HeadersVisibility="Column"
                      AlternatingRowBackground="#F8F9F9"
                      GridLinesVisibility="None" RowHeight="35" FontSize="14"
                      ColumnHeaderHeight="35"
                      BorderBrush="#D5DBDB" BorderThickness="1"
                      SelectionMode="Single" SelectionUnit="FullRow">

                <!-- Header gọn gàng -->
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment"   Value="Center"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding"    Value="8,0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <!-- Ô dữ liệu -->
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="8,0"/>
                        <Setter Property="TextBlock.TextTrimming" Value="CharacterEllipsis"/>
                        <Setter Property="TextBlock.TextWrapping" Value="NoWrap"/>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <!-- ID -->
                    <DataGridTextColumn Header="ID" Binding="{Binding XeMayID}" Width="70">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="TextAlignment"       Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Biển số -->
                    <DataGridTextColumn Header="Biển số" Binding="{Binding BKS}" Width="150"/>

                    <!-- ID cư dân -->
                    <DataGridTextColumn Header="ID cư dân" Binding="{Binding CuDanID}" Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Tên cư dân -->
                    <DataGridTextColumn Header="Tên cư dân" Binding="{Binding TenCuDan}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</UserControl>
