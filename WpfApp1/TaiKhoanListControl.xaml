<UserControl x:Class="WpfApp1.TaiKhoanListControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F6F7">
    <Border Background="White" CornerRadius="10" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0" Text="👥 Tất cả tài khoản"
                       FontSize="20" FontWeight="Bold"
                       Foreground="#2C3E50" Margin="0,0,0,15"/>

            <!-- Search -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
                <TextBox x:Name="txtSearch" Width="300" Height="35"
                         VerticalContentAlignment="Center" FontSize="14"
                         Margin="0,0,10,0" Padding="8"
                         BorderBrush="#BDC3C7" BorderThickness="1"
                         ToolTip="Tìm theo Username / Họ tên / Email / Vai trò"/>
                <Button Content="🔍 Tìm kiếm" Width="120" Height="35"
                        Background="#7D3C98" Foreground="White"
                        FontWeight="Bold" BorderThickness="0"
                        Cursor="Hand" Click="BtnSearch_Click"/>
            </StackPanel>

            <!-- Actions -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,15">
                <Button Content="🔄 Tải lại" Width="100" Height="35"
            Margin="5,0" Background="#3498DB" Foreground="White"
            FontWeight="Bold" BorderThickness="0" Cursor="Hand"
            Click="BtnReload_Click"/>
                <Button Content="👁 Xem" Width="100" Height="35"
            Margin="5,0" Background="#5DADE2" Foreground="White"
            FontWeight="Bold" BorderThickness="0" Cursor="Hand"
            Click="BtnView_Click"/>
                <Button Content="➕ Thêm" Width="100" Height="35"
            Margin="5,0" Background="#58D68D" Foreground="White"
            FontWeight="Bold" BorderThickness="0" Cursor="Hand"
            Click="BtnAdd_Click"/>
                <Button Content="✏ Sửa" Width="100" Height="35"
            Margin="5,0" Background="#F5B041" Foreground="White"
            FontWeight="Bold" BorderThickness="0" Cursor="Hand"
            Click="BtnEdit_Click"/>
                <Button Content="🗑 Xóa" Width="100" Height="35"
            Margin="5,0" Background="#E74C3C" Foreground="White"
            FontWeight="Bold" BorderThickness="0" Cursor="Hand"
            Click="BtnDelete_Click"/>
            </StackPanel>


            <!-- Grid -->
            <DataGrid x:Name="dgTaiKhoan" Grid.Row="3"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserAddRows="False" HeadersVisibility="Column"
                      AlternatingRowBackground="#F8F9F9"
                      GridLinesVisibility="None" RowHeight="35" FontSize="14"
                      BorderBrush="#D5DBDB" BorderThickness="1">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"        Binding="{Binding TaiKhoanID}" Width="70"/>
                    <DataGridTextColumn Header="Username"  Binding="{Binding Username}"   Width="150"/>
                    <DataGridTextColumn Header="Họ tên"    Binding="{Binding HoTen}"      Width="*"/>
                    <DataGridTextColumn Header="Email"     Binding="{Binding Email}"      Width="220"/>
                    <DataGridTextColumn Header="Vai trò"   Binding="{Binding VaiTro}"     Width="140"/>
                    <DataGridTextColumn Header="Trạng thái" Binding="{Binding TrangThai}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</UserControl>
