<Window x:Class="WpfApp1.AIWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WpfApp1"
        Title="AI Trợ Lý" Height="700" Width="1000"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBg}"
        AllowDrop="True"
        PreviewDragOver="Window_PreviewDragOver"
        Drop="Window_Drop">

    <!-- ===== Resources & Themes ===== -->
    <Window.Resources>
        <!-- Theme colors -->
        <SolidColorBrush x:Key="WindowBg" Color="#0F1115"/>
        <SolidColorBrush x:Key="CardBg"   Color="#1A1D23"/>
        <SolidColorBrush x:Key="TitleFg"  Color="White"/>
        <SolidColorBrush x:Key="SubFg"    Color="#B0B4BF"/>

        <!-- Input colors -->
        <SolidColorBrush x:Key="InputBg"  Color="#FFFFFF"/>
        <SolidColorBrush x:Key="InputBrd" Color="#A6B1FF"/>

        <!-- Header gradient -->
        <LinearGradientBrush x:Key="HeaderGrad" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#6C5CE7" Offset="0"/>
            <GradientStop Color="#3C40C6" Offset="1"/>
        </LinearGradientBrush>

        <!-- Accent gradient cho viền logo -->
        <LinearGradientBrush x:Key="IconAccentGrad" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#B66DFF" Offset="0"/>
            <GradientStop Color="#6C8BFF" Offset="1"/>
        </LinearGradientBrush>

        <!-- Logo vector -->
        <DrawingImage x:Key="BotLogo">
            <DrawingImage.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="{DynamicResource IconAccentGrad}">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="1,1,30,30" RadiusX="8" RadiusY="8"/>
                                <PathGeometry Figures="M30,22 L36,26 30,28 Z"/>
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#FFFFFF">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="3,3,26,26" RadiusX="7" RadiusY="7"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#111111">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <EllipseGeometry Center="12,16" RadiusX="2.6" RadiusY="2.6"/>
                                <EllipseGeometry Center="22,16" RadiusX="2.6" RadiusY="2.6"/>
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingImage.Drawing>
        </DrawingImage>

        <!-- Converters -->
        <local:BoolToAlignConverter      x:Key="BoolToAlign"/>
        <local:BoolToBrushConverter      x:Key="BoolToBrush"      UserHex="#27AE60" AiHex="#ECECEC"/>
        <local:BoolToTextBrushConverter  x:Key="BoolToTextBrush"  UserHex="#FFFFFF" AiHex="#2C3E50"/>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibility"/>

        <!-- Styles -->
        <Style x:Key="ChatBubble" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="MaxWidth" Value="640"/>
            <Setter Property="Background" Value="#ECECEC"/>
        </Style>

        <Style x:Key="RoundedTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBrd}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd" CornerRadius="12"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="0" BlurRadius="8" Opacity="0.15"/>
                            </Border.Effect>
                            <ScrollViewer x:Name="PART_ContentHost"
                                          VerticalScrollBarVisibility="Auto"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#8EA2FF"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#5B6CFF"/>
                                <Setter TargetName="bd" Property="BorderThickness" Value="2"/>
                                <Setter Property="Background" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="10"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="8,2"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.6"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.95"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Item lịch sử -->
        <Style TargetType="ListBoxItem" x:Key="HistItem">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="card" CornerRadius="12" Background="#141721" BorderBrush="#242A37" BorderThickness="1" SnapsToDevicePixels="True">
                            <Grid Margin="10">
                                <ContentPresenter/>
                            </Grid>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.18"/>
                            </Border.Effect>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="card" Property="BorderBrush" Value="#3C40C6"/>
                                <Setter TargetName="card" Property="Background" Value="#171C29"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="card" Property="BorderBrush" Value="#6C5CE7"/>
                                <Setter TargetName="card" Property="Background" Value="#1E2231"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ===== Layout ===== -->
    <Grid Background="{DynamicResource WindowBg}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="colSidebar" Width="0"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#0B0D12" BorderBrush="#22262F" BorderThickness="0,0,1,0">
            <!-- Dùng Grid để chủ động hàng header + danh sách -->
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header + Search (NẰM NGANG) -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Lịch sử" Foreground="{DynamicResource TitleFg}" FontWeight="Bold" FontSize="16"/>
                        <TextBlock Text="  ●" Foreground="#6C5CE7" FontSize="16"/>
                    </StackPanel>

                    <Border Grid.Column="2" Background="#121521" BorderBrush="#242A37" BorderThickness="1" CornerRadius="10" Padding="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="🔎" VerticalAlignment="Center" Margin="4,0,8,0" Foreground="#A7B0C5"/>
                            <TextBox x:Name="txtSearchHist"
                                     Grid.Column="1"
                                     Height="34" FontSize="12"
                                     Padding="6"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Foreground="{DynamicResource TitleFg}"
                                     ToolTip="Tìm trong lịch sử trò chuyện"
                                     TextChanged="txtSearchHist_TextChanged"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Danh sách lịch sử (FILL + SCROLL) -->
                <ListBox Grid.Row="1" x:Name="lstConversations"
                         Background="Transparent" BorderThickness="0"
                         Foreground="{DynamicResource TitleFg}"
                         ItemContainerStyle="{StaticResource HistItem}"
                         SelectionChanged="lstConversations_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Text="{Binding Title, FallbackValue=WpfApp1.Conversation}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TitleFg}"
                                           TextTrimming="CharacterEllipsis"/>

                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="{Binding Messages[0].Message}"
                                               Foreground="{DynamicResource SubFg}" FontSize="11"
                                               TextTrimming="CharacterEllipsis" Width="170"/>
                                    <TextBlock Text=" • " Foreground="{DynamicResource SubFg}" FontSize="11"/>
                                    <TextBlock Text="{Binding CreatedUtc, StringFormat={}{0:dd/MM/yyyy HH:mm}}"
                                               Foreground="{DynamicResource SubFg}" FontSize="11"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Main -->
        <Border Grid.Column="1" Background="{DynamicResource CardBg}" CornerRadius="14" Margin="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Padding="16,12" CornerRadius="14,14,0,0" Grid.Row="0" Background="{DynamicResource HeaderGrad}">
                    <DockPanel LastChildFill="True">
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                            <Button x:Name="btnMenu" Content="☰" Width="40" Height="34"
                                    Background="#00000022" Foreground="White"
                                    Style="{StaticResource RoundedButton}"
                                    Click="btnMenu_Click"/>
                            <Viewbox Width="34" Height="34" Margin="10,0,0,0">
                                <Image Source="{DynamicResource BotLogo}"/>
                            </Viewbox>
                            <StackPanel Orientation="Vertical" Margin="10,0,0,0">
                                <TextBlock x:Name="lblTitle" Text="AI Trợ Lý"
                                           FontSize="22" FontWeight="Bold"
                                           Foreground="White"/>
                                <TextBlock x:Name="lblMode" Text=""
                                           Foreground="#E8E8FF" FontStyle="Italic"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <Button x:Name="btnTheme" Content="☀️ Light"
                                    Margin="8,0,0,0" Width="110" Height="34"
                                    Style="{StaticResource RoundedButton}"
                                    Background="#00000022"
                                    Click="btnTheme_Click"/>
                            <Button Content="+ Cuộc trò chuyện mới"
                                    Margin="8,0,0,0" Height="34"
                                    Style="{StaticResource RoundedButton}"
                                    Background="#00000022"
                                    Click="BtnNewChat_Click"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Chat -->
                <ScrollViewer x:Name="svChat" Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,4,0,4">
                    <ItemsControl x:Name="icChat" Margin="16">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Vertical"
                                            HorizontalAlignment="{Binding IsUser, Converter={StaticResource BoolToAlign}}">
                                    <Border Style="{StaticResource ChatBubble}"
                                            Background="{Binding IsUser, Converter={StaticResource BoolToBrush}}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Message}" TextWrapping="Wrap"
                                                       Foreground="{Binding IsUser, Converter={StaticResource BoolToTextBrush}}"/>
                                            <ItemsControl ItemsSource="{Binding Attachments}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="6,8,0,0" Padding="6" CornerRadius="8"
                                                                Background="#FFFFFF33" BorderBrush="#FFFFFF55" BorderThickness="1">
                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                <Image Source="{Binding Thumbnail}"
                                                                       Width="54" Height="54" Margin="0,0,8,0"
                                                                       Stretch="UniformToFill"
                                                                       Visibility="{Binding IsImage, Converter={StaticResource BoolToVisibility}}"/>
                                                                <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" Width="180" TextWrapping="Wrap"/>
                                                                <Button Content="Mở" Style="{StaticResource RoundedButton}" Margin="8,0,0,0"
                                                                        Background="#0984E3" Height="28" Padding="10,0"
                                                                        Click="OpenAttachment_Click"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Input -->
                <Border Grid.Row="2" Background="#F3F4F6" Padding="12" CornerRadius="0,0,14,14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>

                        <ScrollViewer Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,8" Height="72"
                                      HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="icPending">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="6" Padding="6" Background="White" BorderBrush="#D0D5DD" BorderThickness="1" CornerRadius="10">
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="{Binding Thumbnail}" Width="40" Height="40" Stretch="UniformToFill"
                                                       Visibility="{Binding IsImage, Converter={StaticResource BoolToVisibility}}"/>
                                                <TextBlock Text="{Binding DisplayName}" Margin="8,0,8,0" VerticalAlignment="Center" Width="160" TextWrapping="Wrap"/>
                                                <Button Content="✕" Width="28" Height="28" Background="#E74C3C" Click="RemovePending_Click"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <TextBox x:Name="txtQuestion" Grid.Row="1" Grid.Column="0"
                                 Style="{StaticResource RoundedTextBox}"
                                 FontSize="14"
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalContentAlignment="Top"
                                 VerticalScrollBarVisibility="Auto"
                                 MinHeight="56" MaxHeight="120"
                                 KeyDown="TxtQuestion_KeyDown"
                                 ToolTip="Enter: xuống dòng  •  Ctrl+Enter: gửi  •  Có thể kéo-thả tệp/ảnh, Ctrl+V dán ảnh"/>

                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                            <Button x:Name="btnMic" Content="🎤" Width="46" Height="46" Margin="0,0,8,0"
                                    Background="#22A6B3" Style="{StaticResource RoundedButton}"
                                    ToolTip="Bật micro (nhấn để nói)"
                                    Click="BtnMic_Click"/>
                            <Button x:Name="btnAttach" Content="📎" Width="46" Height="46" Margin="0,0,8,0"
                                    Background="#6366F1" Style="{StaticResource RoundedButton}" Click="BtnAttach_Click"/>
                            <Button x:Name="btnSend" Content="➤" Width="56" Height="46"
                                    Style="{StaticResource RoundedButton}" Background="#27AE60"
                                    Click="BtnSend_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Mic label (ngoài ô nhập) -->
                <TextBlock x:Name="lblMic" Grid.Row="3" Margin="18,6,0,10"
                           Foreground="#7F8C8D" FontSize="11" Text="Mic: Tắt"/>
            </Grid>
        </Border>
    </Grid>
</Window>
